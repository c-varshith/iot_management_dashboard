<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    settings.fxml — Application Settings screen
    Controller: com.iot.dashboard.controller.SettingsController
-->
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.iot.dashboard.controller.SettingsController"
            prefWidth="500" prefHeight="620"
            styleClass="panel-root">

    <!-- Define toggle group -->
    <fx:define>
        <ToggleGroup fx:id="dhtToggleGroup"/>
    </fx:define>

    <!-- ── HEADER ─────────────────────────────────────────── -->
    <top>
        <VBox styleClass="panel-header" spacing="0">
            <HBox alignment="CENTER_LEFT" spacing="0">
                <!-- Title block -->
                <VBox HBox.hgrow="ALWAYS" spacing="3">
                    <Label text="Application Settings" styleClass="panel-title" />
                    <Label text="Configure database connection and sensor settings"
                           styleClass="panel-subtitle" />
                </VBox>
                <!-- Sensor mode toggle -->
                <VBox alignment="CENTER" spacing="5">
                    <Label text="SENSOR MODE"
                           style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #4A5568;" />
                    <ToggleButton fx:id="modeToggleButton"
                                  text="Simulation"
                                  styleClass="toggle-btn-panel" />
                </VBox>
            </HBox>
        </VBox>
    </top>

    <!-- ── CONTENT ────────────────────────────────────────── -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-background: transparent;">
            <VBox spacing="16" style="-fx-padding: 20;">

                <!-- Database Configuration -->
                <TitledPane text="Database Configuration" collapsible="false">
                    <VBox spacing="0">

                        <VBox spacing="5">
                            <Label text="DATABASE URL" styleClass="panel-field-label" />
                            <TextField fx:id="dbUrlField"
                                       promptText="jdbc:mysql://localhost:3306/iot_dashboard?..."
                                       styleClass="panel-field, panel-field-mono">
                                <VBox.margin><Insets bottom="10"/></VBox.margin>
                            </TextField>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="USERNAME" styleClass="panel-field-label" />
                            <TextField fx:id="dbUsernameField"
                                       promptText="e.g., root"
                                       styleClass="panel-field">
                                <VBox.margin><Insets bottom="10"/></VBox.margin>
                            </TextField>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="PASSWORD" styleClass="panel-field-label" />
                            <PasswordField fx:id="dbPasswordField"
                                           promptText="Enter your MySQL password"
                                           styleClass="panel-field">
                                <VBox.margin><Insets bottom="10"/></VBox.margin>
                            </PasswordField>
                        </VBox>

                        <Label text="⚠  Password is stored in the external config file — not in source code."
                               styleClass="panel-warning" />
                    </VBox>
                </TitledPane>

                <!-- Sensor Configuration -->
                <TitledPane text="Sensor Configuration" collapsible="false">
                    <VBox spacing="12">

                        <Label text="DHT SENSOR TYPE" styleClass="panel-field-label" />

                        <!-- DHT22 -->
                        <HBox spacing="14" alignment="CENTER_LEFT"
                              styleClass="dht-option-card">
                            <RadioButton fx:id="dht22Radio" text="DHT22"
                                         toggleGroup="$dhtToggleGroup"
                                         styleClass="radio-button" />
                            <VBox fx:id="dht22DescriptionBox" spacing="2">
                                <Label text="Higher accuracy  ±0.5 °C · ±2–5 % RH"
                                       styleClass="dht-card-label-primary" />
                                <Label text="Range −40 to 80 °C · Recommended"
                                       styleClass="dht-card-label-secondary" />
                            </VBox>
                        </HBox>

                        <!-- DHT11 -->
                        <HBox spacing="14" alignment="CENTER_LEFT"
                              styleClass="dht-option-card">
                            <RadioButton fx:id="dht11Radio" text="DHT11"
                                         toggleGroup="$dhtToggleGroup"
                                         styleClass="radio-button" />
                            <VBox fx:id="dht11DescriptionBox" spacing="2">
                                <Label text="Lower accuracy  ±2 °C · ±5 % RH"
                                       styleClass="dht-card-label-primary" />
                                <Label text="Range 0 to 50 °C · Budget option"
                                       styleClass="dht-card-label-secondary" />
                            </VBox>
                        </HBox>

                        <Label text="Only applies in Real Sensor mode — ignored during simulation."
                               styleClass="panel-status-dim" />

                        <Separator><VBox.margin><Insets top="4" bottom="4"/></VBox.margin></Separator>

                        <VBox spacing="5">
                            <Label fx:id="serialPortLabel" text="SERIAL PORT" styleClass="panel-field-label" />
                            <TextField fx:id="serialPortField"
                                       promptText="e.g., /dev/ttyUSB0 (Linux) or COM3 (Windows)"
                                       styleClass="panel-field">
                                <VBox.margin><Insets bottom="8"/></VBox.margin>
                            </TextField>
                        </VBox>

                        <VBox spacing="5">
                            <Label fx:id="baudRateLabel" text="BAUD RATE" styleClass="panel-field-label" />
                            <TextField fx:id="baudRateField"
                                       promptText="9600"
                                       styleClass="panel-field">
                                <VBox.margin><Insets bottom="4"/></VBox.margin>
                            </TextField>
                        </VBox>

                        <Label text="Common baud rates: 9600, 115200"
                               styleClass="panel-status-dim" />
                    </VBox>
                </TitledPane>

                <!-- Status label -->
                <Label fx:id="statusLabel" text="" wrapText="true"
                       styleClass="panel-status-ok" />
            </VBox>
        </ScrollPane>
    </center>

    <!-- ── FOOTER ─────────────────────────────────────────── -->
    <bottom>
        <HBox spacing="10" alignment="CENTER_RIGHT"
              styleClass="panel-footer">
            <Button fx:id="cancelButton" text="Cancel"
                    styleClass="btn-secondary" />
            <Button fx:id="saveButton" text="Save &amp; Apply"
                    styleClass="btn-accent"
                    defaultButton="true" />
        </HBox>
    </bottom>

</BorderPane>
