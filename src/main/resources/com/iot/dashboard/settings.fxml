<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.iot.dashboard.controller.SettingsController"
            prefWidth="500"
            prefHeight="620">

    <!-- Define shared objects before any node references them -->
    <fx:define>
        <ToggleGroup fx:id="dhtToggleGroup"/>
    </fx:define>

    <!-- ================================================================
         HEADER — title left, Simulation/Real Sensor toggle top-right
         ================================================================ -->
    <top>
        <VBox style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-width: 0 0 1 0;">
            <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Application Settings"
                           style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <Label text="Configure database and sensor settings"
                           style="-fx-font-size: 11; -fx-text-fill: #666; -fx-padding: 4 0 0 0;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="4">
                    <Label text="Sensor Mode"
                           style="-fx-font-size: 11; -fx-text-fill: #333; -fx-font-weight: bold;"/>
                    <ToggleButton fx:id="modeToggleButton"
                                  text="Simulation"
                                  style="-fx-font-size: 12; -fx-padding: 6 16; -fx-cursor: hand;
                                         -fx-background-radius: 20; -fx-border-radius: 20;
                                         -fx-border-color: #0ea5e9; -fx-border-width: 2;
                                         -fx-background-color: transparent; -fx-text-fill: #0ea5e9;"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <!-- ================================================================
         CONTENT
         ================================================================ -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-border: none; -fx-background: transparent;">
            <VBox spacing="20" style="-fx-padding: 20;">

                <!-- Database Configuration -->
                <TitledPane text="Database Configuration" collapsible="false">
                    <VBox spacing="12" style="-fx-padding: 15;">
                        <Label text="Database URL:"
                               style="-fx-font-weight: bold; -fx-font-size: 12; -fx-text-fill: #333;"/>
                        <TextField fx:id="dbUrlField"
                                   promptText="jdbc:mysql://localhost:3306/iot_dashboard?..."
                                   style="-fx-padding: 10; -fx-font-family: 'Courier New'; -fx-font-size: 11; -fx-text-fill: #333;">
                            <VBox.margin><Insets bottom="10"/></VBox.margin>
                        </TextField>

                        <Label text="Username:"
                               style="-fx-font-weight: bold; -fx-font-size: 12; -fx-text-fill: #333;"/>
                        <TextField fx:id="dbUsernameField" promptText="e.g., root"
                                   style="-fx-padding: 10; -fx-font-size: 11; -fx-text-fill: #333;">
                            <VBox.margin><Insets bottom="10"/></VBox.margin>
                        </TextField>

                        <Label text="Password:"
                               style="-fx-font-weight: bold; -fx-font-size: 12; -fx-text-fill: #333;"/>
                        <PasswordField fx:id="dbPasswordField"
                                       promptText="Enter your MySQL password"
                                       style="-fx-padding: 10; -fx-font-size: 11; -fx-text-fill: #333;">
                            <VBox.margin><Insets bottom="10"/></VBox.margin>
                        </PasswordField>

                        <Label text="⚠ Password is stored in the external config file, not in source code"
                               style="-fx-font-size: 11; -fx-text-fill: #ff9800; -fx-font-style: italic;"/>
                    </VBox>
                </TitledPane>

                <!-- Sensor Configuration -->
                <TitledPane text="Sensor Configuration" collapsible="false">
                    <VBox spacing="12" style="-fx-padding: 15;">

                        <Label text="DHT Sensor Type:"
                               style="-fx-font-weight: bold; -fx-font-size: 12; -fx-text-fill: #333;"/>

                        <!-- DHT22 option -->
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <RadioButton fx:id="dht22Radio" text="DHT22"
                                         toggleGroup="$dhtToggleGroup"
                                         style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                            <VBox fx:id="dht22DescriptionBox">
                                <Label text="Higher accuracy  ±0.5 °C · ±2–5 % RH"
                                       style="-fx-font-size: 11; -fx-text-fill: #555;"/>
                                <Label text="Range −40 to 80 °C · Recommended"
                                       style="-fx-font-size: 11; -fx-text-fill: #777;"/>
                            </VBox>
                        </HBox>

                        <!-- DHT11 option -->
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <RadioButton fx:id="dht11Radio" text="DHT11"
                                         toggleGroup="$dhtToggleGroup"
                                         style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                            <VBox fx:id="dht11DescriptionBox">
                                <Label text="Lower accuracy  ±2 °C · ±5 % RH"
                                       style="-fx-font-size: 11; -fx-text-fill: #555;"/>
                                <Label text="Range 0 to 50 °C · Budget option"
                                       style="-fx-font-size: 11; -fx-text-fill: #777;"/>
                            </VBox>
                        </HBox>

                        <Label text="Only applies in Real Sensor mode — ignored during simulation."
                               style="-fx-font-size: 11; -fx-text-fill: #999; -fx-font-style: italic;"/>

                        <Separator><VBox.margin><Insets top="4" bottom="4"/></VBox.margin></Separator>

                        <Label fx:id="serialPortLabel" text="Serial Port:"
                               style="-fx-font-weight: bold; -fx-font-size: 12; -fx-text-fill: #333;"/>
                        <TextField fx:id="serialPortField"
                                   promptText="e.g., /dev/ttyUSB0 (Linux) or COM3 (Windows)"
                                   style="-fx-padding: 10; -fx-font-size: 11; -fx-text-fill: #333;">
                            <VBox.margin><Insets bottom="10"/></VBox.margin>
                        </TextField>

                        <Label fx:id="baudRateLabel" text="Baud Rate:"
                               style="-fx-font-weight: bold; -fx-font-size: 12; -fx-text-fill: #333;"/>
                        <TextField fx:id="baudRateField" promptText="9600"
                                   style="-fx-padding: 10; -fx-font-size: 11; -fx-text-fill: #333;">
                            <VBox.margin><Insets bottom="10"/></VBox.margin>
                        </TextField>

                        <Label text="Common baud rates: 9600, 115200"
                               style="-fx-font-size: 11; -fx-text-fill: #999; -fx-font-style: italic;"/>
                    </VBox>
                </TitledPane>

                <Label fx:id="statusLabel" text="" wrapText="true"
                       style="-fx-font-size: 12; -fx-text-fill: #4caf50; -fx-font-weight: bold;"/>
            </VBox>
        </ScrollPane>
    </center>

    <!-- ================================================================
         FOOTER
         ================================================================ -->
    <bottom>
        <HBox spacing="10" alignment="CENTER_RIGHT"
              style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-width: 1 0 0 0;">
            <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
            <Button fx:id="cancelButton" text="Cancel"
                    style="-fx-padding: 8 20; -fx-font-size: 11;"/>
            <Button fx:id="saveButton" text="Save &amp; Apply"
                    style="-fx-padding: 8 20; -fx-font-size: 11; -fx-font-weight: bold;
                           -fx-text-fill: white; -fx-background-color: #4caf50;"/>
        </HBox>
    </bottom>

</BorderPane>
