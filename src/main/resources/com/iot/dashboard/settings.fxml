<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.iot.dashboard.controller.SettingsController"
            prefWidth="500"
            prefHeight="600">

    <!-- Header -->
    <top>
        <VBox style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>
            <Label text="Application Settings" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #333;"/>
            <Label text="Configure database and sensor settings" style="-fx-font-size: 11; -fx-text-fill: #666; -fx-padding: 5 0 0 0;"/>
        </VBox>
    </top>

    <!-- Content -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-border: none; -fx-background: transparent;">
            <VBox spacing="20" style="-fx-padding: 20;">

                <!-- Database Settings Section -->
                <TitledPane text="Database Configuration" collapsible="false">
                    <VBox spacing="12" style="-fx-padding: 15;">

                        <Label text="Database URL:" style="-fx-font-weight: bold; -fx-font-size: 11; -fx-text-fill: #555;"/>
                        <TextField fx:id="dbUrlField"
                                   promptText="jdbc:mysql://localhost:3306/iot_dashboard?..."
                                   style="-fx-padding: 8; -fx-font-family: 'Courier New';">
                            <VBox.margin>
                                <Insets bottom="10"/>
                            </VBox.margin>
                        </TextField>

                        <Label text="Username:" style="-fx-font-weight: bold; -fx-font-size: 11; -fx-text-fill: #555;"/>
                        <TextField fx:id="dbUsernameField"
                                   promptText="e.g., root"
                                   style="-fx-padding: 8;">
                            <VBox.margin>
                                <Insets bottom="10"/>
                            </VBox.margin>
                        </TextField>

                        <Label text="Password:" style="-fx-font-weight: bold; -fx-font-size: 11; -fx-text-fill: #555;"/>
                        <PasswordField fx:id="dbPasswordField"
                                       promptText="Enter your MySQL password"
                                       style="-fx-padding: 8;">
                            <VBox.margin>
                                <Insets bottom="10"/>
                            </VBox.margin>
                        </PasswordField>

                        <Label text="⚠ Password is stored in the external config file and applied without editing source files"
                               style="-fx-font-size: 10; -fx-text-fill: #ff9800; -fx-font-style: italic;"/>
                    </VBox>
                </TitledPane>

                <!-- Sensor Configuration Section -->
                <TitledPane text="Sensor Configuration" collapsible="false">
                    <VBox spacing="12" style="-fx-padding: 15;">

                        <CheckBox fx:id="useRealSensorCheckbox"
                                  text="Use Real Sensor (Temperature &amp; Humidity)"
                                  style="-fx-font-size: 11;">
                            <VBox.margin>
                                <Insets bottom="10"/>
                            </VBox.margin>
                        </CheckBox>

                        <Label text="Use the dashboard toggle for quick switching after launch"
                               style="-fx-font-size: 10; -fx-text-fill: #666; -fx-padding: -5 0 0 0;"/>
                        <Label text="When disabled: All 4 sensors are simulated"
                               style="-fx-font-size: 10; -fx-text-fill: #666; -fx-padding: -5 0 5 0;"/>
                        <Label text="When enabled: Arduino provides Temperature/Humidity, Voltage/Power are simulated"
                               style="-fx-font-size: 10; -fx-text-fill: #666; -fx-padding: 0 0 10 0;"/>

                        <Separator/>

                        <Label text="Serial Port:" style="-fx-font-weight: bold; -fx-font-size: 11; -fx-text-fill: #555;"/>
                        <TextField fx:id="serialPortField"
                                   promptText="e.g., /dev/ttyUSB0 (Linux) or COM3 (Windows)"
                                   style="-fx-padding: 8;">
                            <VBox.margin>
                                <Insets bottom="10"/>
                            </VBox.margin>
                        </TextField>

                        <Label text="Baud Rate:" style="-fx-font-weight: bold; -fx-font-size: 11; -fx-text-fill: #555;"/>
                        <TextField fx:id="baudRateField"
                                   promptText="9600"
                                   style="-fx-padding: 8;">
                            <VBox.margin>
                                <Insets bottom="10"/>
                            </VBox.margin>
                        </TextField>

                        <Label text="Common baud rates: 9600, 115200"
                               style="-fx-font-size: 10; -fx-text-fill: #666; -fx-font-style: italic;"/>
                    </VBox>
                </TitledPane>

                <!-- Status Message -->
                <Label fx:id="statusLabel"
                       text=""
                       wrapText="true"
                       style="-fx-font-size: 11; -fx-text-fill: #4caf50;">
                </Label>

            </VBox>
        </ScrollPane>
    </center>

    <!-- Footer Buttons -->
    <bottom>
        <HBox spacing="10"
              style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-width: 1 0 0 0;"
              alignment="CENTER_RIGHT">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>

            <Button fx:id="cancelButton"
                    text="Cancel"
                    style="-fx-padding: 8 20; -fx-font-size: 11;">
            </Button>

            <Button fx:id="saveButton"
                    text="Save &amp; Apply"
                    style="-fx-padding: 8 20; -fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: white; -fx-background-color: #4caf50;">
            </Button>
        </HBox>
    </bottom>

</BorderPane>
