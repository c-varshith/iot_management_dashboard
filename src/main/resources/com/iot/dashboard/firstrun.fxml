<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<!--
    firstrun.fxml — First-run database credentials screen
    Controller: com.iot.dashboard.controller.FirstRunController
-->
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.iot.dashboard.controller.FirstRunController"
            prefWidth="480" prefHeight="540"
            styleClass="panel-root">

    <!-- ── HEADER ─────────────────────────────────────────── -->
    <top>
        <VBox styleClass="panel-header" spacing="0">
            <HBox alignment="CENTER_LEFT" spacing="14">
                <ImageView fitWidth="40" fitHeight="40" preserveRatio="true" smooth="true">
                    <image><Image url="@logo.png" /></image>
                </ImageView>
                <VBox spacing="2">
                    <Label text="Welcome to IoT Dashboard"
                           styleClass="panel-title" />
                    <Label text="Connect your MySQL database to get started."
                           styleClass="panel-subtitle" />
                </VBox>
            </HBox>
        </VBox>
    </top>

    <!-- ── FORM ───────────────────────────────────────────── -->
    <center>
        <VBox styleClass="panel-body" spacing="14" style="-fx-padding: 24 32 16 32;">

            <!-- Database Host -->
            <VBox spacing="5">
                <Label text="DATABASE HOST URL" styleClass="panel-field-label" />
                <TextField fx:id="dbUrlField"
                           promptText="jdbc:mysql://localhost:3306/iot_dashboard"
                           styleClass="panel-field, panel-field-mono" />
            </VBox>

            <!-- Username -->
            <VBox spacing="5">
                <Label text="USERNAME" styleClass="panel-field-label" />
                <TextField fx:id="usernameField"
                           promptText="e.g., root"
                           styleClass="panel-field" />
            </VBox>

            <!-- Password -->
            <VBox spacing="5">
                <Label text="PASSWORD" styleClass="panel-field-label" />
                <PasswordField fx:id="passwordField"
                               promptText="Your MySQL password"
                               styleClass="panel-field" />
            </VBox>

            <!-- Status / error -->
            <Label fx:id="statusLabel" text="" wrapText="true"
                   styleClass="panel-status-err" />

            <!-- Config path info -->
            <Label fx:id="configPathLabel" text=""
                   styleClass="panel-status-dim" />

        </VBox>
    </center>

    <!-- ── FOOTER ─────────────────────────────────────────── -->
    <bottom>
        <VBox styleClass="panel-footer" spacing="8">
            <Label text="Credentials are saved to your user profile — never stored in source code."
                   styleClass="panel-status-dim" />
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button fx:id="exitButton" text="Exit"
                        styleClass="exit-btn" />
                <Button fx:id="connectButton" text="Connect &amp; Launch"
                        styleClass="btn-accent"
                        defaultButton="true" />
            </HBox>
        </VBox>
    </bottom>

</BorderPane>
