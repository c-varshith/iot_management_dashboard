<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.iot.dashboard.controller.FirstRunController"
            prefWidth="480" prefHeight="420"
            style="-fx-background-color: #1a1a2e;">

    <top>
        <VBox style="-fx-background-color: #16213e; -fx-padding: 24 28 20 28;">
            <Label text="Welcome to IoT Dashboard"
                   style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #00d4ff;"/>
            <Label text="Enter your MySQL credentials to get started."
                   style="-fx-font-size: 12; -fx-text-fill: #aaa; -fx-padding: 6 0 0 0;"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="14" style="-fx-padding: 24 28 10 28;">

            <Label text="Database Host URL:"
                   style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #ccc;"/>
            <TextField fx:id="dbUrlField"
                       style="-fx-padding: 9; -fx-background-color: #0f3460;
                              -fx-text-fill: white; -fx-prompt-text-fill: #666;
                              -fx-font-family: 'Courier New'; -fx-font-size: 11;"/>

            <Label text="Username:"
                   style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #ccc;"/>
            <TextField fx:id="usernameField"
                       promptText="e.g., root"
                       style="-fx-padding: 9; -fx-background-color: #0f3460;
                              -fx-text-fill: white; -fx-prompt-text-fill: #666;"/>

            <Label text="Password:"
                   style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #ccc;"/>
            <PasswordField fx:id="passwordField"
                           promptText="Your MySQL password"
                           style="-fx-padding: 9; -fx-background-color: #0f3460;
                                  -fx-text-fill: white; -fx-prompt-text-fill: #666;"/>

            <Label fx:id="statusLabel" text="" wrapText="true"
                   style="-fx-font-size: 11; -fx-text-fill: #ff6b6b; -fx-padding: 4 0 0 0;"/>

            <Label fx:id="configPathLabel" text=""
                   style="-fx-font-size: 10; -fx-text-fill: #888; -fx-font-style: italic;"/>
        </VBox>
    </center>

    <bottom>
        <VBox style="-fx-background-color: #16213e; -fx-padding: 14 28 20 28;" spacing="10">
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button fx:id="exitButton" text="Exit"
                        style="-fx-padding: 9 22; -fx-background-color: #444;
                               -fx-text-fill: white; -fx-cursor: hand;"/>
                <Button fx:id="connectButton" text="Connect &amp; Launch"
                        style="-fx-padding: 9 22; -fx-background-color: #00d4ff;
                               -fx-text-fill: #0a0a1a; -fx-font-weight: bold; -fx-cursor: hand;"/>
            </HBox>
            <Label text="Credentials are saved to your user profile — not stored in the app."
                   style="-fx-font-size: 10; -fx-text-fill: #555;"/>
        </VBox>
    </bottom>

</BorderPane>
