# ============================================================
# IoT Dashboard — Database Configuration Template
#
# SETUP INSTRUCTIONS:
#   1. Copy this file:  cp database.properties.example database.properties
#   2. Fill in your MySQL credentials below
#   3. database.properties is git-ignored — your password stays local
# ============================================================

# JDBC URL — change host/port/dbname if not using defaults
db.url=jdbc:mysql://localhost:3306/iot_dashboard?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&rewriteBatchedStatements=true

# MySQL credentials — use a dedicated user, NOT root, in production
db.username=YOUR_MYSQL_USERNAME
db.password=YOUR_MYSQL_PASSWORD

# Sensor mode — the dashboard toggle updates this automatically after login
use.real.sensor=false
serial.port=/dev/ttyUSB0
baud.rate=9600

# DHT sensor type — DHT11 or DHT22 (ignored in simulation mode)
# DHT22 has higher accuracy (±0.5°C, ±2–5% RH) and wider range; DHT11 is cheaper
dht.type=DHT22

# ============================================================
# HikariCP Connection Pool (safe defaults — tune for production)
# ============================================================
hikari.maximumPoolSize=10
hikari.minimumIdle=2
hikari.connectionTimeout=30000
hikari.idleTimeout=600000
hikari.maxLifetime=1800000
hikari.poolName=IoTDashboard-HikariPool
